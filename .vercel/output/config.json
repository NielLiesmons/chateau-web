{
	"version": 3,
	"routes": [
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/communities/?(?:/__data.json)?$",
			"dest": "/communities"
		},
		{
			"src": "^/communities/create/?(?:/__data.json)?$",
			"dest": "/communities/create"
		},
		{
			"src": "^/communities/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/communities/[communityNpub]"
		},
		{
			"src": "^/communities/([^/]+?)/forum/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/communities/[communityNpub]/forum/[eventId]"
		},
		{
			"src": "^/communities/([^/]+?)/post/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/communities/[communityNpub]/post/[eventId]"
		},
		{
			"src": "^/profile/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/profile/[npub]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}